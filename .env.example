ENV=development
LOG_LEVEL=info

# Postgres bootstrap
POSTGRES_USER=
POSTGRES_PASSWORD=

# Service databases
POSTGRES_AUTH_DSN=
POSTGRES_USER_DSN=
POSTGRES_ROOM_DSN=
POSTGRES_MESSAGE_DSN=

# Service database users
POSTGRES_AUTH_USER=
POSTGRES_AUTH_PASSWORD=
POSTGRES_USER_USER=
POSTGRES_USER_PASSWORD=
POSTGRES_ROOM_USER=
POSTGRES_ROOM_PASSWORD=
POSTGRES_MESSAGE_USER=
POSTGRES_MESSAGE_PASSWORD=

# Valkey
VALKEY_PASSWORD=
VALKEY_ADDR=valkey:6379

# NATS
NATS_URL=nats://nats:4222
NATS_USER=
NATS_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Ports
AUTH_GRPC_PORT=50051
USER_GRPC_PORT=50052
ROOM_GRPC_PORT=50053
MESSAGE_GRPC_PORT=50054
WEBSOCKET_HTTP_PORT=8081
GATEWAY_HTTP_PORT=8080

# Service addresses
AUTH_SERVICE_ADDR=auth:50051
USER_SERVICE_ADDR=user:50052
ROOM_SERVICE_ADDR=room:50053
MESSAGE_SERVICE_ADDR=message:50054

# Optional observability
GRAFANA_USER=
GRAFANA_PASSWORD=

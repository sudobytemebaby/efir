# =============================================================================
# Efir — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
!.env.example

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.dev.yml
!docker-compose.dev.example.yml

# -----------------------------------------------------------------------------
# SSL certificates
# -----------------------------------------------------------------------------
infra/traefik/certs/

# -----------------------------------------------------------------------------
# Go build artifacts
# -----------------------------------------------------------------------------
bin/
vendor/

# Go test cache & coverage
*.test
*.out
coverage.html

# -----------------------------------------------------------------------------
# Proto generated code
# генерируется в CI через buf generate, не коммитится
# -----------------------------------------------------------------------------
proto/gen/

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------

# JetBrains (GoLand, IntelliJ)
.idea/
*.iml

# VSCode
.vscode/
*.code-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Taskfile
# -----------------------------------------------------------------------------
.task/
.instruct.md

# -----------------------------------------------------------------------------
# Test & coverage artifacts
# -----------------------------------------------------------------------------
*.coverprofile
dist/
